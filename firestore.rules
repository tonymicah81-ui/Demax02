rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net — deny everything unless explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // GLOBAL HELPERS
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin') ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
      );
    }

    // ===============================================================
    // ENTITY VALIDATION HELPERS
    // ===============================================================

    function isValidUser(data) {
      return data.uid == request.auth.uid  // Fixed: was request.auth.id (typo)
        && data.username is string && data.username.size() >= 2 && data.username.size() <= 50
        && data.email is string && data.email.size() <= 100
        && data.role == 'user'
        && data.status == 'active'
        && data.balance == 0;
    }

    function isValidProject(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.status in ["In Queue", "Domain Registered", "Email Configured", "Live Chat Enabled", "Deployed", "Completed", "pending", "domain bought", "hosted", "delivered"]
        && (data.domainName == null || (data.domainName is string && data.domainName.size() <= 255));
    }

    function isValidTransaction(data) {
      return data.userId == request.auth.uid
        && data.amount is number && data.amount > 0
        && data.type in ['deposit', 'payment', 'refund']
        && data.status == 'pending';
    }

    function isValidAuditLog(data) {
      return data.adminId == request.auth.uid
        && data.action is string && data.action.size() <= 200
        && data.createdAt == request.time;
    }

    // ===============================================================
    // USERS COLLECTION
    // ===============================================================

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      allow create: if isSignedIn() && request.auth.uid == userId
        && isValidUser(incoming())
        && incoming().keys().hasAll(['uid', 'username', 'email', 'role', 'status', 'balance'])
        && incoming().keys().size() == 8; // uid, username, email, phoneNumber, tfaEnabled, role, status, balance + createdAt

      allow update: if isSuperAdmin() || (
        isSignedIn() && request.auth.uid == userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['username', 'phone', 'phoneNumber', 'address', 'tfaEnabled'])
        && incoming().username is string && incoming().username.size() <= 50
      );
    }

    // ===============================================================
    // ADMINS COLLECTION
    // ===============================================================

    match /admins/{adminId} {
      // Admins can read their own profile; super admin can read all
      allow read: if isSignedIn() && (request.auth.uid == adminId || isSuperAdmin());

      // Only allow creation from authenticated context (vault signup flow)
      allow create: if isSignedIn() && request.auth.uid == adminId
        && incoming().uid == request.auth.uid
        && incoming().role == 'admin'
        && incoming().status == 'inactive';

      // Super admin can update any admin; admin can update own non-sensitive fields
      allow update: if isSuperAdmin() || (
        isSignedIn() && request.auth.uid == adminId
        && incoming().diff(existing()).affectedKeys().hasOnly(['username', 'phoneNumber', 'personalEmail'])
      );

      allow delete: if isSuperAdmin();
    }

    // ===============================================================
    // ADMIN SECRETS — password stored separately, super admin only
    // ===============================================================

    match /admin_secrets/{adminId} {
      allow read: if isSuperAdmin();
      allow create: if isSignedIn() && request.auth.uid == adminId;
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ===============================================================
    // PROJECTS
    // ===============================================================

    match /projects/{projectId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() && isValidProject(incoming());
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'domainName', 'expiryDate', 'notes'])
      );
      allow delete: if isSuperAdmin();
    }

    // ===============================================================
    // TRANSACTIONS
    // ===============================================================

    match /transactions/{id} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      allow create: if isVerified() && isValidTransaction(incoming())
        && incoming().keys().hasAll(['userId', 'amount', 'type', 'status', 'createdAt'])
        && incoming().createdAt == request.time;

      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'adminNote', 'processedAt'])
        && incoming().status in ['approved', 'declined', 'completed']
      );
    }

    // ===============================================================
    // AUDIT LOGS
    // ===============================================================

    match /audit_logs/{id} {
      allow read: if isSuperAdmin();
      allow create: if isAdmin() && isValidAuditLog(incoming());
    }

    // ===============================================================
    // CHATS / MESSAGES
    // ===============================================================

    match /chats/{chatId} {
      function isParticipant() {
        return request.auth.uid in resource.data.participants;
      }

      allow read: if isAdmin() || (isSignedIn() && isParticipant());

      allow create: if isSignedIn()
        && incoming().participants.size() >= 2
        && request.auth.uid in incoming().participants;

      allow update: if isAdmin() || (isSignedIn() && isParticipant() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt', 'unreadCount'])
      ));

      match /messages/{messageId} {
        allow read: if isAdmin() || (isSignedIn() &&
          get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]));
        allow create: if isSignedIn()
          && incoming().senderId == request.auth.uid
          && incoming().text is string && incoming().text.size() <= 5000
          && incoming().createdAt == request.time;
      }
    }

    // Also support "conversations" collection used by chatService
    match /conversations/{convId} {
      function isConvParticipant() {
        return request.auth.uid in resource.data.participants;
      }
      allow read: if isAdmin() || (isSignedIn() && isConvParticipant());
      allow create: if isSignedIn() && request.auth.uid in incoming().participants;
      allow update: if isAdmin() || (isSignedIn() && isConvParticipant());

      match /messages/{messageId} {
        allow read: if isAdmin() || (isSignedIn() &&
          get(/databases/$(database)/documents/conversations/$(convId)).data.participants.hasAny([request.auth.uid]));
        allow create: if isSignedIn()
          && incoming().senderId == request.auth.uid
          && incoming().createdAt == request.time;
      }
    }

    // ===============================================================
    // NOTIFICATIONS
    // ===============================================================

    match /user_notifications/{id} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || resource.data.userId == "all"
      );
      allow create: if isAdmin();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }

    // ===============================================================
    // MARKETPLACE
    // ===============================================================

    match /categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /sub_categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /products/{id} { allow read: if true; allow write: if isAdmin(); }
    match /subscription_models/{id} { allow read: if true; allow write: if isAdmin(); }

    // ===============================================================
    // SYSTEM CONFIG (payment details etc.)
    // ===============================================================

    match /system_config/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // ===============================================================
    // PLATFORM SETTINGS — super admin managed
    // ===============================================================

    match /platform_settings/{docId} {
      // Vault status, loading config, and general settings are readable by all
      // (needed for vault gate check, loading screen, and support email display)
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ===============================================================
    // VAULT ALERTS — written by unauthenticated vault gate on lockout
    // ===============================================================

    match /vault_alerts/{id} {
      allow read: if isSuperAdmin();
      allow create: if true; // Gate needs to write even without auth
    }

  }
}
