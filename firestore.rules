rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════
    // GLOBAL SAFETY NET — deny everything unless explicitly allowed
    // ═══════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Admin: in admins collection with role 'admin' or 'super_admin'
    // 'client' = pending approval — does NOT grant admin access
    function isAdmin() {
      return isSignedIn() && (
        (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in ['admin', 'super_admin']
        ) || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']
        )
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin'
        ) || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
        )
      );
    }

    // ═══════════════════════════════════════════════════════════════
    // ENTITY VALIDATORS
    // ═══════════════════════════════════════════════════════════════

    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.username is string && data.username.size() >= 2 && data.username.size() <= 50
        && data.email is string && data.email.size() <= 100
        && data.role == 'user'
        && data.status == 'active'
        && data.balance == 0;
    }

    function isValidProject(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.status in [
          'In Queue', 'Domain Registered', 'Email Configured',
          'Live Chat Enabled', 'Deployed', 'Completed',
          'pending', 'domain bought', 'hosted', 'delivered'
        ]
        && (data.domainName == null || (data.domainName is string && data.domainName.size() <= 255));
    }

    function isValidTransaction(data) {
      return data.userId == request.auth.uid
        && data.amount is number
        && data.type in ['deposit', 'payment', 'refund', 'adjustment']
        && (
          (data.type == 'deposit' && data.amount > 0 && data.status == 'pending') ||
          (data.type == 'payment' && data.status == 'completed') ||
          (data.type == 'refund' && data.status == 'completed') ||
          (data.type == 'adjustment')
        );
    }

    // ═══════════════════════════════════════════════════════════════
    // VAULT — PIN gate config + attempt tracking
    // ═══════════════════════════════════════════════════════════════

    match /vault/{docId} {
      allow read: if true;
      allow create: if isSuperAdmin();
      allow delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || (
        docId == 'config' &&
        incoming().diff(existing()).affectedKeys()
          .hasOnly(['lastTimeVisit', 'countTryNumber', 'lastLockTime'])
      );
    }

    // ═══════════════════════════════════════════════════════════════
    // USERS
    // ═══════════════════════════════════════════════════════════════

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      allow create: if isSignedIn() && request.auth.uid == userId
        && isValidUser(incoming())
        && incoming().keys().hasAll(['uid', 'username', 'email', 'phoneNumber', 'role', 'status', 'balance', 'createdAt']);

      allow update: if isSuperAdmin() || isAdmin() || (
        isSignedIn() && request.auth.uid == userId
        && incoming().diff(existing()).affectedKeys()
            .hasOnly(['username', 'phoneNumber', 'address'])
        && incoming().username is string && incoming().username.size() <= 50
      );

      allow delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // ADMINS
    // ═══════════════════════════════════════════════════════════════

    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isSuperAdmin());

      allow create: if isSignedIn() && request.auth.uid == adminId
        && incoming().uid == request.auth.uid
        && incoming().role == 'client'
        && incoming().status == 'inactive';

      allow update: if isSuperAdmin() || (
        isSignedIn() && request.auth.uid == adminId
        && incoming().diff(existing()).affectedKeys()
            .hasOnly(['username', 'phoneNumber', 'personalEmail'])
      );

      allow delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // ADMIN SECRETS
    // ═══════════════════════════════════════════════════════════════

    match /admin_secrets/{adminId} {
      allow read: if isSuperAdmin();
      allow create: if isSignedIn() && request.auth.uid == adminId;
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // PROJECTS
    // ═══════════════════════════════════════════════════════════════

    match /projects/{projectId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() && isValidProject(incoming());
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys()
          .hasOnly(['status', 'domainName', 'expiryDate', 'notes', 'updatedAt'])
      );
      allow delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // TRANSACTIONS
    // ═══════════════════════════════════════════════════════════════

    match /transactions/{id} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get:  if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      // Users can create deposits (pending) and checkout payments (completed)
      // Admins can create any transaction type (adjustments, refunds)
      allow create: if isAdmin() || (
        isSignedIn() && isValidTransaction(incoming())
        && incoming().keys().hasAll(['userId', 'amount', 'type', 'status', 'createdAt'])
      );

      // Admin can approve/decline deposits
      allow update: if isAdmin()
        && existing().status == 'pending'
        && incoming().diff(existing()).affectedKeys()
            .hasOnly(['status', 'adminNote', 'processedAt'])
        && incoming().status in ['approved', 'declined', 'completed'];
    }

    // ═══════════════════════════════════════════════════════════════
    // ORDERS
    // ═══════════════════════════════════════════════════════════════

    match /orders/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // RECEIPTS — public read for verification, user creates own
    // ═══════════════════════════════════════════════════════════════

    match /receipts/{id} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // SESSIONS — 48h login session tracking
    // ═══════════════════════════════════════════════════════════════

    match /sessions/{sessionId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin() || (
        isSignedIn() && resource.data.userId == request.auth.uid
        && incoming().diff(existing()).affectedKeys()
            .hasOnly(['lastActive', 'active', 'revokedAt', 'expiresAt'])
      );
      allow delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // VISITOR CARTS — anonymous / pre-login cart
    // Non-sensitive data: product IDs and names only
    // ═══════════════════════════════════════════════════════════════

    match /visitor_carts/{id} {
      allow read, write: if true;
    }

    // ═══════════════════════════════════════════════════════════════
    // MARKETPLACE VIEWS — public product view tracking
    // ═══════════════════════════════════════════════════════════════

    match /marketplace_views/{id} {
      allow create: if true;
      allow read: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // CARTS — authenticated user cart items
    // ═══════════════════════════════════════════════════════════════

    match /carts/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // ═══════════════════════════════════════════════════════════════
    // AUDIT LOGS
    // ═══════════════════════════════════════════════════════════════

    match /audit_logs/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && incoming().adminId == request.auth.uid
        && incoming().action is string && incoming().action.size() <= 200;
    }

    // ═══════════════════════════════════════════════════════════════
    // CONVERSATIONS & MESSAGES (chat system)
    // ═══════════════════════════════════════════════════════════════

    match /conversations/{convId} {
      allow read: if isAdmin() || (
        isSignedIn() && resource.data.userId == request.auth.uid
      );
      allow create: if isSignedIn()
        && incoming().userId == request.auth.uid;
      allow update: if isAdmin() || (
        isSignedIn() && resource.data.userId == request.auth.uid
        && incoming().diff(existing()).affectedKeys()
            .hasOnly(['lastMessage', 'lastMessageAt', 'unreadCount', 'typing', 'status'])
      );
      allow delete: if isSuperAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAdmin() || (
        isSignedIn() && resource.data.senderId == request.auth.uid
      );
      allow create: if isSignedIn()
        && incoming().senderId == request.auth.uid
        && incoming().text is string && incoming().text.size() <= 5000;
      allow update: if isAdmin() || (
        isSignedIn() && resource.data.senderId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'edited', 'deleted'])
      );
      allow delete: if isSuperAdmin();
    }

    // Legacy chats collection
    match /chats/{chatId} {
      function isParticipant() {
        return request.auth.uid in resource.data.participants;
      }
      allow read: if isAdmin() || (isSignedIn() && isParticipant());
      allow create: if isSignedIn()
        && incoming().participants.size() >= 2
        && request.auth.uid in incoming().participants;
      allow update: if isAdmin() || (isSignedIn() && isParticipant());

      match /messages/{messageId} {
        allow read: if isAdmin() || (isSignedIn() &&
          get(/databases/$(database)/documents/chats/$(chatId)).data.participants
            .hasAny([request.auth.uid]));
        allow create: if isSignedIn()
          && incoming().senderId == request.auth.uid
          && incoming().text is string && incoming().text.size() <= 5000;
        allow update: if isAdmin() || (isSignedIn() && resource.data.senderId == request.auth.uid);
      }
    }

    // ═══════════════════════════════════════════════════════════════
    // NOTIFICATIONS
    // ═══════════════════════════════════════════════════════════════

    match /user_notifications/{id} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || resource.data.userId == 'all'
      );
      // Admin OR the user themselves (for checkout notifications)
      allow create: if isAdmin() || (isSignedIn() && incoming().userId == request.auth.uid);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSuperAdmin();
    }

    match /admin_notifications/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin() || isSignedIn();
      allow update: if isAdmin()
        && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // MARKETPLACE
    // ═══════════════════════════════════════════════════════════════

    match /categories/{id}          { allow read: if true; allow write: if isAdmin(); }
    match /sub_categories/{id}      { allow read: if true; allow write: if isAdmin(); }
    match /products/{id}            { allow read: if true; allow write: if isAdmin(); }
    match /subscription_models/{id} { allow read: if true; allow write: if isAdmin(); }

    // ═══════════════════════════════════════════════════════════════
    // FIXES / BUG REPORTS
    // ═══════════════════════════════════════════════════════════════

    match /fixes/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin() || (
        isSignedIn() && resource.data.userId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      allow delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // ISSUES
    // ═══════════════════════════════════════════════════════════════

    match /issues/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin() || (
        isSignedIn() && resource.data.userId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      allow delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // SUBSCRIPTIONS
    // ═══════════════════════════════════════════════════════════════

    match /subscriptions/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // SYSTEM CONFIG
    // ═══════════════════════════════════════════════════════════════

    match /system_config/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // PLATFORM SETTINGS — publicly readable (loading screen, Cloudinary config)
    // ═══════════════════════════════════════════════════════════════

    match /platform_settings/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

  }
}
